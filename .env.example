# Токены T-Invest API — по одному на каждый режим работы CLI.
# Как получить: настройки Т-Инвестиций → раздел «Токены T-Invest API».
# КУДА КЛАСТЬ: это шаблон. Скопируйте его в ~/.config/tinvest/.env — CLI читает
# .env ТОЛЬКО оттуда (не из текущей папки). Реальные переменные окружения имеют
# приоритет над файлом.
#
# Режим выбирается флагом --mode (sandbox | readonly | full).
# Если заполнен ровно один токен — режим определяется автоматически.

# Песочница: виртуальный счёт, отдельный контур API (тип токена — «песочница»).
T_INVEST_TOKEN_SANDBOX=

# Боевой счёт, токен «только чтение» — не может совершать сделки.
T_INVEST_TOKEN_READONLY=

# Боевой счёт, реальные сделки. Уровень токена — «Торговля» (НЕ «Торговля и
# переводы»: переводы/выводы средств CLI не использует, лишний scope не нужен).
# ВАЖНО: само наличие этого токена НЕ разрешает торговать — нужен флаг ниже.
T_INVEST_TOKEN_FULL=

# --- Разрешение реальных сделок (environment-specific capability) ---
# Гейт денег вынесен в окружение: включает его владелец окружения (деплой), а
# не агент. Без флагов режим full работает только на чтение.

# Разрешить реальные сделки в режиме full. Каждая заявка при этом требует
# подтверждения флагом --confirm (подпись человека на конкретную сделку).
T_INVEST_ALLOW_TRADING=

# STONKS-режим: разрешить сделки реальными деньгами БЕЗ подтверждений
# (полностью автономный агент). Подразумевает T_INVEST_ALLOW_TRADING.
# ОПАСНО: вы передаёте агенту полный автономный доступ к счёту. Включайте
# только осознанно. Значения: true | 1 | yes | on.
T_INVEST_STONKS_MODE=

# Идентификатор сессии (необязательно). Нужен только если под одним пользователем
# ОДНОВРЕМЕННО работают несколько агентов/сессий — тогда у каждого свой активный
# режим и они не перезаписывают его друг другу. Для одного агента не нужен.
TINVEST_SESSION_ID=
