{
  "name": "t-invest-skill",
  "version": "0.1.0",
  "description": "CLI + Claude Code скилл для Т-Инвестиций (T-Invest API): портфель, котировки, поиск инструментов, история операций",
  "type": "module",
  "bin": {
    "tinvest": "./dist/cli.js"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "build:skill": "esbuild src/cli.ts --bundle --platform=node --target=node20 --format=cjs --outfile=skill/scripts/tinvest.cjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "commander": "^14.0.0",
    "dotenv": "^17.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.30.0",
    "@types/node": "^24.0.0",
    "esbuild": "^0.28.1",
    "eslint": "^9.30.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.35.0",
    "vitest": "^3.2.0"
  },
  "allowScripts": {
    "esbuild@0.28.1": true
  }
}
